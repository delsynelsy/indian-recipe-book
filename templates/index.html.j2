<!-- ═══ HEADER ════════════════════════════════════════════════════ -->
<header>
  <h1>Recetario Vintage Indio</h1>
  <span class="orn">✦ &nbsp; ✦ &nbsp; ✦</span>
  <p class="sub">Plan de Alimentación · 8 Semanas · Edición Clásica</p>
</header>
<div class="themes">
  <button class="tbtn on" onclick="setT('sepia',this)">◈ Sepia Dorado</button>
  <button class="tbtn"    onclick="setT('sage',this)">◈ Verde Salvia</button>
  <button class="tbtn"    onclick="setT('indigo',this)">◈ Azul Índigo</button>
</div>

<!-- ═══ GRID ══════════════════════════════════════════════════════ -->
<main><div class="grid">

{% for recipe in recipes %}
<div class="card" onclick="openModal('{{ recipe.id }}')">
  <div class="img-wrap">
    <img class="card-img {{ recipe.image.css_class }}" src="{{ recipe.image.src }}" alt="{{ recipe.name }}">
    <div class="vignette"></div><div class="img-frame"></div>
    <div class="img-title">{{ recipe.name }}</div>
    <div class="card-cta"><div class="cta-btn">Ver Receta Completa</div></div>
  </div>
  <div class="card-body">
    <div class="tags">{% for tag in recipe.tags %}<span class="tag">{{ tag }}</span>{% endfor %}</div>
    <h2 class="ctitle">{{ recipe.name }}</h2>
    <div class="macros"><div><b>{{ recipe.nutrition.kcal }}</b> kcal</div><div>P: <b>{{ recipe.nutrition.protein }}g</b></div><div>C: <b>{{ recipe.nutrition.carbs }}g</b></div><div>G: <b>{{ recipe.nutrition.fat }}g</b></div></div>
    <div class="pills">{% for ing in recipe.highlight_ingredients %}<span class="pill">{% set _slug = ing | ing_slug %}{% if ingredient_icons.get(_slug) %}<img class="pill-icon" src="{{ ingredient_icons[_slug] }}" alt="" loading="lazy">{% endif %}{{ ing }}</span>{% endfor %}</div>
  </div>
</div>
{% endfor %}

</div></main>

<!-- ═══ RECIPE DETAIL MODAL ═══════════════════════════════════════ -->
<div class="recipe-modal" id="recipeModal" role="dialog" aria-modal="true">
  <div class="modal-scrim" onclick="closeModal()"></div>
  <div class="modal-panel">
    <div class="modal-topbar">
      <button class="modal-back" onclick="closeModal()">← Recetario</button>
      <div class="modal-topbar-title" id="modalTopTitle"></div>
      <button class="modal-preview-btn" onclick="openPreview()">⊕ Previsualizar</button>
    </div>
    <div class="modal-body">
      <div class="modal-left">
        <div class="modal-hero-wrap">
          <img id="modalHeroImg" class="modal-hero-img" src="" alt="">
          <div class="modal-hero-vignette"></div>
          <div class="modal-hero-frame"></div>
        </div>
        <div class="modal-info">
          <h2 class="modal-recipe-name" id="modalName"></h2>
          <p class="modal-recipe-sub" id="modalSub"></p>
          <div class="modal-tags" id="modalTags"></div>
          <div class="modal-meta-row" id="modalMeta"></div>
          <div class="macro-grid" id="modalMacros"></div>
        </div>
      </div>
      <div class="modal-right" id="modalRight"></div>
    </div>
  </div>
</div>

<!-- ═══ PRINT PREVIEW MODAL ══════════════════════════════════════ -->
<div class="preview-modal" id="previewModal" role="dialog" aria-modal="true">
  <div class="preview-panel">
    <div class="preview-toolbar">
      <button class="prev-btn" onclick="closePreview()">← Volver</button>
      <div class="preview-title-bar">Vista Previa · Receta Completa</div>
      <button class="prev-btn accent" onclick="window.print()">⊕ Imprimir</button>
    </div>
    <div class="preview-scroll" id="previewScroll"></div>
  </div>
</div>

<script>
const R = {{ recipes_json | safe }};

/* ── DOM helpers ─────────────────────────────────────────────── */
function el(tag, cls, text) {
  const e = document.createElement(tag);
  if (cls) e.className = cls;
  if (text !== undefined) e.textContent = text;
  return e;
}
function append(parent, ...children) {
  children.forEach(c => parent.appendChild(c));
  return parent;
}

/* ── Build icon <svg> via DOM ────────────────────────────────── */
function buildIcon(ic) {
  const ns = 'http://www.w3.org/2000/svg';
  const svg = document.createElementNS(ns, 'svg');
  svg.setAttribute('viewBox', '0 0 48 48');
  const use = document.createElementNS(ns, 'use');
  use.setAttributeNS('http://www.w3.org/1999/xlink', 'href', '#ic-' + ic);
  svg.appendChild(use);
  return svg;
}

/* ── Build tag span ──────────────────────────────────────────── */
function buildTag(text, cls) {
  return el('span', cls || 'modal-tag', text);
}

/* ── Build macro cell ────────────────────────────────────────── */
function buildMacroCell(val, lbl) {
  const cell = el('div', 'macro-cell');
  append(cell, el('span', 'macro-val', String(val)), el('span', 'macro-lbl', lbl));
  return cell;
}

/* ── Build step item ─────────────────────────────────────────── */
function buildStep(s, i) {
  const li = el('li', 'step-item');
  const num = el('div', 'step-num', String(i + 1).padStart(2, '0'));
  const iconWrap = el('div', 'step-icon-wrap');
  iconWrap.appendChild(buildIcon(s.ic));
  const textDiv = el('div', 'step-text');
  const actionRow = el('div', 'step-action-row', s.act);
  if (s.t) {
    const timeSpan = el('span', 'step-time', s.t);
    actionRow.appendChild(timeSpan);
  }
  const desc = el('p', 'step-desc', s.txt);
  append(textDiv, actionRow, desc);
  append(li, num, iconWrap, textDiv);
  return li;
}

/* ── Build ingredient item ───────────────────────────────────── */
const INGREDIENT_ICONS = {{ ingredient_icons_json | default('{}') }};
const INGREDIENT_SLUGS = Object.keys(INGREDIENT_ICONS);

function _ingSlug(s) {
  return s.normalize('NFKD').replace(/[̀-ͯ]/g, '')
          .toLowerCase().replace(/[^\w\s-]/g, '').trim().replace(/\s+/g, '_').slice(0, 60);
}

function _matchIcon(text) {
  /* Fuzzy match: any known slug appearing as substring of slugified ingredient line. */
  const haystack = _ingSlug(text);
  for (const slug of INGREDIENT_SLUGS) {
    if (haystack.includes(slug)) return INGREDIENT_ICONS[slug];
  }
  return null;
}

function buildIngredient(text) {
  const li = el('li', 'ingredient-item');
  const url = _matchIcon(text);
  if (url) {
    const img = el('img', 'ingredient-icon');
    img.src = url; img.alt = ''; img.loading = 'lazy';
    append(li, img);
  }
  append(li, el('span', null, text));
  return li;
}

/* ═══ OPEN MODAL ════════════════════════════════════════════════ */
let currentId = null;

function openModal(id) {
  currentId = id;
  const r = R[id];

  document.getElementById('modalTopTitle').textContent = r.name;
  document.getElementById('modalName').textContent = r.name;
  document.getElementById('modalSub').textContent = r.sub;

  const img = document.getElementById('modalHeroImg');
  img.src = r.img;
  img.className = 'modal-hero-img ' + r.imgCls;
  img.alt = r.name;

  /* tags */
  const tagsEl = document.getElementById('modalTags');
  tagsEl.innerHTML = '';
  [r.phase, r.meal, r.type].forEach(t => tagsEl.appendChild(buildTag(t)));

  /* meta */
  const metaEl = document.getElementById('modalMeta');
  metaEl.innerHTML = '';
  const metaData = [
    { ic: '⏱', txt: r.prep + (r.prepNote ? ' ' + r.prepNote : '') },
    { ic: '🍳', txt: r.cook + ' cocción' },
    { ic: '🍽', txt: r.servings },
  ];
  metaData.forEach(m => {
    const item = el('div', 'meta-item');
    append(item, el('span', null, m.ic + ' '), el('span', null, m.txt));
    metaEl.appendChild(item);
  });

  /* macros */
  const macroEl = document.getElementById('modalMacros');
  macroEl.innerHTML = '';
  [
    [r.kcal, 'kcal'], [r.p + 'g', 'proteína'],
    [r.c + 'g', 'carbos'], [r.g + 'g', 'grasas']
  ].forEach(([v, l]) => macroEl.appendChild(buildMacroCell(v, l)));

  /* right panel */
  const right = document.getElementById('modalRight');
  right.innerHTML = '';

  /* ingredients section */
  const ingHead = el('div', 'section-head');
  ingHead.appendChild(el('h3', null, 'Ingredientes'));
  const ingList = el('ul', 'ingredients-list');
  r.ingredients.forEach(i => ingList.appendChild(buildIngredient(i)));
  append(right, ingHead, ingList);

  /* steps section */
  const stepsHead = el('div', 'section-head');
  stepsHead.appendChild(el('h3', null, 'Procedimiento'));
  const stepsList = el('ol', 'steps-list');
  r.steps.forEach((s, i) => stepsList.appendChild(buildStep(s, i)));
  append(right, stepsHead, stepsList);

  /* tip */
  if (r.tip) {
    const tipBox = el('div', 'tip-box');
    const tipContent = el('div');
    const tipLabel = el('div', 'tip-lbl', 'Consejo del chef');
    const tipText = el('p', 'tip-text', r.tip);
    append(tipContent, tipLabel, tipText);
    append(tipBox, el('span', null, '💡'), tipContent);
    right.appendChild(tipBox);
  }

  document.getElementById('recipeModal').classList.add('open');
  document.body.style.overflow = 'hidden';
}

function closeModal() {
  document.getElementById('recipeModal').classList.remove('open');
  document.body.style.overflow = '';
}

/* ═══ PREVIEW / PRINT ═══════════════════════════════════════════ */
function openPreview() {
  if (!currentId) return;
  const r = R[currentId];
  const scroll = document.getElementById('previewScroll');
  scroll.innerHTML = '';

  const card = el('div', 'print-card');

  /* header */
  const hdr = el('div', 'print-header');
  append(hdr,
    el('h1', 'print-recipe-name', r.name),
    el('p', 'print-sub', r.sub)
  );
  const tagsDiv = el('div', 'print-tags');
  [r.phase, r.meal, r.type].forEach(t => tagsDiv.appendChild(el('span', 'print-tag', t)));
  hdr.appendChild(tagsDiv);
  const metaDiv = el('div', 'print-meta');
  [
    [r.prep + (r.prepNote ? ' ' + r.prepNote : ''), 'Preparación'],
    [r.cook, 'Cocción'],
    [r.servings, 'Porciones']
  ].forEach(([v, l]) => {
    const item = el('div', 'print-meta-item');
    append(item, el('span', 'print-meta-val', v), el('span', null, l));
    metaDiv.appendChild(item);
  });
  hdr.appendChild(metaDiv);
  card.appendChild(hdr);

  /* body: 2 columns */
  const body = el('div', 'print-body');

  /* left: ingredients + macros */
  const ingCol = el('div', 'print-ingredients');
  ingCol.appendChild(el('h4', 'print-col-label', 'Ingredientes'));
  const ingUl = el('ul');
  r.ingredients.forEach(i => {
    const li = el('li');
    li.textContent = i;
    ingUl.appendChild(li);
  });
  ingCol.appendChild(ingUl);
  const macroGrid = el('div', 'print-macros');
  [
    [r.kcal, 'kcal'], [r.p + 'g', 'proteína'],
    [r.c + 'g', 'carbos'], [r.g + 'g', 'grasas']
  ].forEach(([v, l]) => {
    const cell = el('div', 'print-macro-cell');
    append(cell, el('div', 'print-macro-val', String(v)), el('div', 'print-macro-lbl', l));
    macroGrid.appendChild(cell);
  });
  ingCol.appendChild(macroGrid);

  /* right: steps */
  const stepsCol = el('div', 'print-steps');
  stepsCol.appendChild(el('h4', 'print-col-label', 'Procedimiento'));
  r.steps.forEach((s, i) => {
    const stepDiv = el('div', 'print-step');
    const numDiv = el('div', 'print-step-num', String(i + 1));
    const bodyDiv = el('div');
    const actDiv = el('div', 'print-step-action', s.act + (s.t ? ' · ' + s.t : ''));
    const descP = el('p', 'print-step-desc', s.txt);
    append(bodyDiv, actDiv, descP);
    append(stepDiv, numDiv, bodyDiv);
    stepsCol.appendChild(stepDiv);
  });
  if (r.tip) {
    const tipDiv = el('div', 'print-tip');
    const bold = el('strong', null, '💡 Consejo: ');
    tipDiv.appendChild(bold);
    tipDiv.appendChild(document.createTextNode(r.tip));
    stepsCol.appendChild(tipDiv);
  }

  append(body, ingCol, stepsCol);
  card.appendChild(body);

  /* footer */
  const ftr = el('div', 'print-footer');
  append(ftr,
    el('span', 'print-orn', '✶ · ✶ · ✶'),
    el('p', null, 'Recetario Vintage Indio · Plan de Alimentación 8 Semanas')
  );
  card.appendChild(ftr);

  scroll.appendChild(card);
  document.getElementById('previewModal').classList.add('open');
}

function closePreview() {
  document.getElementById('previewModal').classList.remove('open');
}

document.addEventListener('keydown', e => {
  if (e.key === 'Escape') {
    if (document.getElementById('previewModal').classList.contains('open')) closePreview();
    else closeModal();
  }
});

function setT(name, btn) {
  document.documentElement.setAttribute('data-theme', name);
  document.querySelectorAll('.tbtn').forEach(b => b.classList.remove('on'));
  btn.classList.add('on');
}
</script>
</body>
</html>
